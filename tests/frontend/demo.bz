func func_w_bin_expr()
  let foo = 10 * 12 + 3 - 1 / 2
  let bar = 10 + 12 / 3 * 4
  let foo_scoped: Int = { 10 * 12 + 3 - 1 / 2}
  let bar_scoped: Int = { 10 - 12 / 3 * 4 - 1 + bar - foo / scoped * unscoped - {
     let a = 10 - foo_scoped * 3 - 12 * 23 - 4 + foo
     a || {2 > 3 || 5 ~= 2 && 5 < 6 - 2 && 4 >= 2 - 3 <= 8}
  }}
  let foobar = foo / bar
  foobar
end

Cmt {
  Language semantic violations will be trapped at the AST level for proper,
  error handling via some external process (ideally the Language Server).
  
  Code containing semantic violations will not compile.
}



Cmt {
  When declaring a constant, we keep constants at the top level scope of 
  the module.
}

const bar =  10 Cmt this is ok

let a = "10"

const bar = "not allowed" 



Cmt {
  Declaring constants elsewhere will be flagged by the compiler and result in, 
  a compile time error. 
}

func const_in_function() :> Nothing 
  let foo = "10"
  const x = 10            Cmt this will not compile
end



Cmt {
  Let bindings are only allowed in Functions scopes. Writing let bindings
  outside of a function scope will be flagged in the AST as `poisoned` and
  will not compile.
}

let doodoo = "dada"        Cmt This will error!
let a = b()                Cmt This will error!



Cmt {
  Same thing with Scoped Expressions. Scoped expressions must stem from a top
  level function scope. Scoped expressions that do not originate from a function
  scope will be flagged in the AST as `poisoned` and will result in a compile time
  error.
}

{                          Cmt Illegal top-level function scope. 
  let x = 10
  let y = 11
}

